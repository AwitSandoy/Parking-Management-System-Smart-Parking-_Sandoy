<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.ColumnConstraints?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #1e293b; -fx-padding: 14;">
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Admin Dashboard" />
            <Label fx:id="welcomeLabel" style="-fx-text-fill: #cbd5e1;" HBox.hgrow="ALWAYS" />
            <Button onAction="#handleLogout" text="Logout" />
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <!-- ===================== SLOTS TAB ===================== -->
            <Tab text="Manage Parking Slots">
                <VBox spacing="12.0">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>

                    <TableView fx:id="slotsTable" prefHeight="240.0">
                        <columns>
                            <TableColumn fx:id="colSlotId" prefWidth="80.0" text="ID" />
                            <TableColumn fx:id="colSlotNumber" prefWidth="150.0" text="Slot Number" />
                            <TableColumn fx:id="colSlotStatus" prefWidth="150.0" text="Status" />
                            <TableColumn fx:id="colSlotRate" prefWidth="150.0" text="Rate / Hour" />
                        </columns>
                    </TableView>

                    <GridPane hgap="10.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100.0" />
                            <ColumnConstraints minWidth="180.0" />
                            <ColumnConstraints minWidth="100.0" />
                            <ColumnConstraints minWidth="180.0" />
                        </columnConstraints>
                        <Label text="Slot Number:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="slotNumberField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Rate / Hour:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <TextField fx:id="slotRateField" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                    </GridPane>

                    <HBox spacing="10.0">
                        <Button onAction="#handleAddSlot" style="-fx-background-color: #16a34a; -fx-text-fill: white;" text="Add Slot" />
                        <Button onAction="#handleUpdateSlot" text="Update Selected" />
                        <Button onAction="#handleDeleteSlot" style="-fx-background-color: #dc2626; -fx-text-fill: white;" text="Delete Selected" />
                        <Button onAction="#handleRefreshSlots" text="Refresh" />
                    </HBox>
                    <Label fx:id="slotsMessageLabel" style="-fx-text-fill: #dc2626;" wrapText="true" />
                </VBox>
            </Tab>

            <!-- ===================== USERS TAB ===================== -->
            <Tab text="Manage Users">
                <VBox spacing="12.0">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>

                    <TableView fx:id="usersTable" prefHeight="240.0">
                        <columns>
                            <TableColumn fx:id="colUserId" prefWidth="80.0" text="ID" />
                            <TableColumn fx:id="colUsername" prefWidth="200.0" text="Username" />
                            <TableColumn fx:id="colUserRole" prefWidth="150.0" text="Role" />
                        </columns>
                    </TableView>

                    <GridPane hgap="10.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100.0" />
                            <ColumnConstraints minWidth="180.0" />
                            <ColumnConstraints minWidth="100.0" />
                            <ColumnConstraints minWidth="180.0" />
                        </columnConstraints>
                        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="newUsernameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Password:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <TextField fx:id="newUserPasswordField" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                        <Label text="Role:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ComboBox fx:id="newUserRoleCombo" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    </GridPane>

                    <HBox spacing="10.0">
                        <Button onAction="#handleAddUser" style="-fx-background-color: #16a34a; -fx-text-fill: white;" text="Add User" />
                        <Button onAction="#handleUpdateUserRole" text="Update Role of Selected" />
                        <Button onAction="#handleDeleteUser" style="-fx-background-color: #dc2626; -fx-text-fill: white;" text="Delete Selected" />
                        <Button onAction="#handleRefreshUsers" text="Refresh" />
                    </HBox>
                    <Label fx:id="usersMessageLabel" style="-fx-text-fill: #dc2626;" wrapText="true" />
                </VBox>
            </Tab>

            <!-- ===================== RESERVATIONS TAB ===================== -->
            <Tab text="View Transactions">
                <VBox spacing="12.0">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>

                    <TableView fx:id="reservationsTable" prefHeight="360.0">
                        <columns>
                            <TableColumn fx:id="colResId" prefWidth="60.0" text="ID" />
                            <TableColumn fx:id="colResUsername" prefWidth="130.0" text="Customer" />
                            <TableColumn fx:id="colResSlotNumber" prefWidth="100.0" text="Slot" />
                            <TableColumn fx:id="colResEntryTime" prefWidth="170.0" text="Entry Time" />
                            <TableColumn fx:id="colResExitTime" prefWidth="170.0" text="Exit Time" />
                            <TableColumn fx:id="colResAmount" prefWidth="110.0" text="Amount" />
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER_RIGHT">
                        <Button onAction="#handleRefreshReservations" text="Refresh" />
                    </HBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.CustomerDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #2563eb; -fx-padding: 14;">
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"
                   text="Customer Dashboard" />
            <Label fx:id="welcomeLabel" style="-fx-text-fill: #dbeafe;" HBox.hgrow="ALWAYS" />
            <Button onAction="#handleLogout" text="Logout" />
        </HBox>
    </top>

    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
            </padding>

            <Label style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Available Parking Slots" />
            <TableView fx:id="availableSlotsTable" prefHeight="220.0">
                <columns>
                    <TableColumn fx:id="colSlotNumber" prefWidth="150.0" text="Slot Number" />
                    <TableColumn fx:id="colStatus" prefWidth="150.0" text="Status" />
                    <TableColumn fx:id="colRate" prefWidth="150.0" text="Rate / Hour" />
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Label fx:id="statusLabel" style="-fx-text-fill: #16a34a;" HBox.hgrow="ALWAYS" />
                <Button onAction="#handleRefresh" text="Refresh" />
                <Button fx:id="bookButton" onAction="#handleBookSlot" style="-fx-background-color: #16a34a; -fx-text-fill: white;" text="Book Now" />
            </HBox>

            <Label style="-fx-font-size: 15px; -fx-font-weight: bold;" text="My Active Reservations" />
            <TableView fx:id="myReservationsTable" prefHeight="180.0">
                <columns>
                    <TableColumn fx:id="colResSlot" prefWidth="120.0" text="Slot" />
                    <TableColumn fx:id="colResEntry" prefWidth="200.0" text="Entry Time" />
                    <TableColumn fx:id="colResAmount" prefWidth="120.0" text="Amount" />
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="releaseButton" onAction="#handleReleaseSlot" style="-fx-background-color: #dc2626; -fx-text-fill: white;" text="Release Selected Slot" />
            </HBox>
        </VBox>
    </center>
</BorderPane>

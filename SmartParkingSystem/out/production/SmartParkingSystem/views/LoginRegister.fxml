<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: #f4f6f8;"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.LoginRegisterController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Smart Parking Management System" />
    <Label fx:id="formTitleLabel" style="-fx-font-size: 16px; -fx-text-fill: #555;" text="Login" />

    <VBox alignment="CENTER" maxWidth="320.0" spacing="10.0">
        <TextField fx:id="usernameField" promptText="Username" />
        <PasswordField fx:id="passwordField" promptText="Password" />

        <!-- Only shown while registering -->
        <PasswordField fx:id="confirmPasswordField" managed="false" promptText="Confirm Password" visible="false" />

        <Label fx:id="messageLabel" style="-fx-text-fill: red;" wrapText="true" />

        <Button fx:id="primaryActionButton" maxWidth="Infinity" onAction="#handlePrimaryAction" text="Login" />
        <Button fx:id="toggleModeButton" maxWidth="Infinity" onAction="#handleToggleMode"
                style="-fx-background-color: transparent; -fx-text-fill: #2563eb;"
                text="Don't have an account? Register" />
    </VBox>
</VBox>
